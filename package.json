{
  "name": "hl-grid-bot-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker:paper": "tsx src/server/workers/paper-loop.ts",
    "worker:propr": "tsx src/server/workers/propr-reconciliation-worker.ts",
    "propr:reconcile:once": "tsx src/server/workers/propr-reconcile-once.ts",
    "docker:local:up": "docker compose -f docker-compose.local.yml up --build -d",
    "docker:local:start": "docker compose -f docker-compose.local.yml start",
    "docker:local:stop": "docker compose -f docker-compose.local.yml stop",
    "docker:local:down": "docker compose -f docker-compose.local.yml down",
    "docker:local:logs": "docker compose -f docker-compose.local.yml logs -f app worker",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up --build -d",
    "docker:prod:start": "docker compose -f docker-compose.prod.yml start",
    "docker:prod:stop": "docker compose -f docker-compose.prod.yml stop",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f app worker",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.2",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ulid": "^3.0.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
