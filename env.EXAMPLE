PROPR_API_KEY=
PROPR_API_URL=https://api.propr.xyz/v1
PROPR_WS_URL=wss://api.propr.xyz/ws
PROPR_ACCOUNT_ID=

APP_AUTH_USERNAME=loic
APP_AUTH_PASSWORD=
# Option multi-utilisateurs. Si defini, remplace APP_AUTH_USERNAME / APP_AUTH_PASSWORD.
# Format: user1:password1,user2:password2
# APP_AUTH_USERS=loic:change-me,marty4k:change-me-too
APP_AUTH_SECRET=

# Credentials Propr optionnels par utilisateur applicatif.
# Sans suffixe, ces valeurs restent le compte par defaut.
# PROPR_API_KEY_MARTY4K=
# PROPR_ACCOUNT_ID_MARTY4K=

DATABASE_URL=file:/app/data/hl_grid_bot.sqlite
PROPR_WORKER_INTERVAL_MS=10000
APP_BIND=127.0.0.1
APP_PORT=3000
